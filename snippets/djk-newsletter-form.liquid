{%- comment -%}
  Renders the brand email capture form.

  Posts to Klaviyo directly when Theme settings > Dylan Koch brand >
  Lead capture platform is set to Klaviyo and both IDs are filled in
  (handled in assets/djk.js). Otherwise stores the lead as a Shopify
  customer.

  Accepts:
  - form_id: {String} unique id for the form inputs
  - placeholder: {String} input placeholder text
  - button_text: {String} submit button label
  - button_style: {String} 'primary' or 'gold'
  - success_text: {String} message after signup
  - note: {String} optional small print under the form

  Usage:
  {% render 'djk-newsletter-form', form_id: section.id, button_text: 'Send Me The Playbook' %}
{%- endcomment -%}

{%- liquid
  assign btn_class = 'djk-btn djk-btn--primary'
  if button_style == 'gold'
    assign btn_class = 'djk-btn djk-btn--gold'
  endif

  assign use_klaviyo = false
  if settings.djk_capture_platform == 'klaviyo' and settings.djk_klaviyo_company_id != blank and settings.djk_klaviyo_list_id != blank
    assign use_klaviyo = true
  endif
-%}

{%- capture newsletter_fields -%}
  <div class="djk-newsletter-form">
    <div class="djk-newsletter-form__field">
      <label class="visually-hidden" for="DjkEmail-{{ form_id }}">{{ 'newsletter.label' | t }}</label>
      <input
        id="DjkEmail-{{ form_id }}"
        type="email"
        name="{% if use_klaviyo %}email{% else %}contact[email]{% endif %}"
        class="djk-newsletter-form__input"
        aria-required="true"
        autocorrect="off"
        autocapitalize="off"
        autocomplete="email"
        placeholder="{{ placeholder | default: 'Enter your email' }}"
        required
      >
    </div>
    <button type="submit" class="{{ btn_class }}" name="commit">
      {{ button_text | default: 'Subscribe' }}
    </button>
  </div>

  {%- if note != blank -%}
    <p class="djk-form-note">{{ note }}</p>
  {%- endif -%}
{%- endcapture -%}

{%- if use_klaviyo -%}
  <form
    class="djk-newsletter"
    method="post"
    data-djk-klaviyo
    data-company="{{ settings.djk_klaviyo_company_id | strip | escape }}"
    data-list="{{ settings.djk_klaviyo_list_id | strip | escape }}"
    data-source="newsletter"
  >
    {{ newsletter_fields }}
    <p class="djk-form-error" data-djk-error hidden>Something went wrong. Please try again.</p>
    <template data-djk-success>
      <div class="djk-form-success" role="status" tabindex="-1">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M2.5 8.5l3.5 3.5L13.5 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span>{{ success_text | default: "You're in. Check your inbox for the Playbook." }}</span>
      </div>
    </template>
  </form>
{%- else -%}
  {% form 'customer', class: 'djk-newsletter', data-klaviyo-subscribe: 'true' %}
    <input type="hidden" name="contact[tags]" value="newsletter">

    {%- if form.posted_successfully? -%}
      <div class="djk-form-success" role="status" tabindex="-1" autofocus>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M2.5 8.5l3.5 3.5L13.5 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span>{{ success_text | default: "You're in. Check your inbox for the Playbook." }}</span>
      </div>
    {%- else -%}
      {{ newsletter_fields }}

      {%- if form.errors -%}
        <p class="djk-form-error" id="DjkEmail-error-{{ form_id }}">
          {{ form.errors.translated_fields.email | capitalize }}
          {{ form.errors.messages.email }}
        </p>
      {%- endif -%}
    {%- endif -%}
  {% endform %}
{%- endif -%}
