{%- comment -%}
  The actual workbook cover from The Direct-to-Fan Operating System PDF,
  rebuilt from the cover page HTML so the website preview matches the
  downloaded document exactly. Scales to its container via container
  query units; all internal sizes are em-based (1em = 10px at the
  original 8.5in page width).
{%- endcomment -%}
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap">

<div class="djk-pbcover" aria-hidden="true">
  <div class="djk-pbcover__edge-top"></div>
  <div class="djk-pbcover__edge-left"></div>
  <div class="djk-pbcover__glow djk-pbcover__glow--tr"></div>
  <div class="djk-pbcover__glow djk-pbcover__glow--bl"></div>

  <div class="djk-pbcover__inner">
    <div class="djk-pbcover__header">
      <span class="djk-pbcover__brand">Dylan Koch &middot; Direct-to-Fan Marketing System</span>
      <span class="djk-pbcover__edition">2025 Edition</span>
    </div>

    <div>
      <div class="djk-pbcover__rule"></div>
      <div class="djk-pbcover__eyebrow">The ACEMM Framework &mdash; Complete Breakdown</div>
      <div class="djk-pbcover__title">THE</div>
      <div class="djk-pbcover__title djk-pbcover__title--ice">DIRECT-TO-FAN</div>
      <div class="djk-pbcover__title djk-pbcover__title--last">OPERATING SYSTEM</div>
      <p class="djk-pbcover__lede">Five stages. Four execution steps each. One connected path from stranger to superfan &mdash; and from superfan to revenue that multiplies.</p>
    </div>

    <div class="djk-pbcover__system">
      <div class="djk-pbcover__system-glow"></div>
      <div class="djk-pbcover__system-label">
        <span class="djk-pbcover__system-dash"></span>
        The Operating System
        <span class="djk-pbcover__system-line"></span>
      </div>

      <div class="djk-pbcover__acemm">
        <div class="djk-pbcover__stage">
          <div class="djk-pbcover__stage-ghost">A</div>
          <div class="djk-pbcover__stage-n">01</div>
          <div class="djk-pbcover__stage-word">ATTRACT</div>
          <div class="djk-pbcover__stage-sub">Strangers discover you</div>
        </div>
        <div class="djk-pbcover__arrow">&rarr;</div>
        <div class="djk-pbcover__stage">
          <div class="djk-pbcover__stage-ghost">C</div>
          <div class="djk-pbcover__stage-n">02</div>
          <div class="djk-pbcover__stage-word">CONNECT</div>
          <div class="djk-pbcover__stage-sub">You own the channel</div>
        </div>
        <div class="djk-pbcover__arrow">&rarr;</div>
        <div class="djk-pbcover__stage">
          <div class="djk-pbcover__stage-ghost">E</div>
          <div class="djk-pbcover__stage-n">03</div>
          <div class="djk-pbcover__stage-word">ENGAGE</div>
          <div class="djk-pbcover__stage-sub">Trust is built</div>
        </div>
        <div class="djk-pbcover__arrow">&rarr;</div>
        <div class="djk-pbcover__stage">
          <div class="djk-pbcover__stage-ghost">M</div>
          <div class="djk-pbcover__stage-n">04</div>
          <div class="djk-pbcover__stage-word">MONETIZE</div>
          <div class="djk-pbcover__stage-sub">The list becomes income</div>
        </div>
        <div class="djk-pbcover__arrow">&rarr;</div>
        <div class="djk-pbcover__stage">
          <div class="djk-pbcover__stage-ghost">M</div>
          <div class="djk-pbcover__stage-n">05</div>
          <div class="djk-pbcover__stage-word">MULTIPLY</div>
          <div class="djk-pbcover__stage-sub">The system scales</div>
        </div>
      </div>
    </div>

    <div class="djk-pbcover__footer">
      <div class="djk-pbcover__footer-tag">A Field Guide for Working Musicians</div>
      <div class="djk-pbcover__footer-sig">
        <div class="djk-pbcover__footer-name">Dylan Koch</div>
        <div class="djk-pbcover__footer-sys">Direct-to-Fan Marketing System</div>
      </div>
    </div>
  </div>
</div>
