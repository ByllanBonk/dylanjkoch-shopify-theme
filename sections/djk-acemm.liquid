{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="djk-section djk-grid-texture color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"{% if section.settings.anchor_id != blank %} id="{{ section.settings.anchor_id }}"{% endif %}>
  <div class="djk-aurora"></div>
  <div class="djk-container" style="position: relative;">
    <div class="djk-section-head djk-section-head--center djk-reveal">
      {%- if section.settings.eyebrow != blank -%}
        <p class="djk-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="djk-heading djk-heading--lg">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="djk-lead">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="djk-acemm__row">
      {%- for block in section.blocks -%}
        <div class="djk-card djk-acemm-stage djk-reveal" style="--djk-delay: {{ forloop.index0 | times: 0.1 }}s;" {{ block.shopify_attributes }}>
          <span class="djk-acemm-stage__letter" aria-hidden="true">{{ block.settings.letter }}</span>
          <h3 class="djk-acemm-stage__title">{{ block.settings.title }}</h3>
          {%- if block.settings.text != blank -%}
            <p class="djk-acemm-stage__text">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.copy != blank -%}
      <div class="djk-acemm__foot djk-reveal">
        {{ section.settings.copy }}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "DJK ACEMM Showcase",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "info": "Optional. Lets buttons link straight to this section."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Framework"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "ACEMM"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text",
      "default": "<p>Five stages. One operating system. Every musician is stuck at exactly one of them.</p>"
    },
    {
      "type": "richtext",
      "id": "copy",
      "label": "Supporting copy",
      "default": "<p>Most musicians don't need to fix everything. They need to identify the next bottleneck.</p><p>ACEMM helps you identify exactly where your growth is getting stuck.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "stage",
      "name": "Stage",
      "settings": [
        {
          "type": "text",
          "id": "letter",
          "label": "Letter",
          "default": "A"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Attract"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Earn the attention of the right listeners."
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "DJK ACEMM Showcase",
      "blocks": [
        { "type": "stage", "settings": { "letter": "A", "title": "Attract", "text": "Earn the attention of the right listeners with content that sounds like you." } },
        { "type": "stage", "settings": { "letter": "C", "title": "Connect", "text": "Move attention onto channels you own. Email first." } },
        { "type": "stage", "settings": { "letter": "E", "title": "Engage", "text": "Build trust with consistent, real communication." } },
        { "type": "stage", "settings": { "letter": "M", "title": "Monetize", "text": "Offer things fans actually want, sold direct." } },
        { "type": "stage", "settings": { "letter": "M", "title": "Multiply", "text": "Scale what works and let fans bring the next fans." } }
      ]
    }
  ]
}
{% endschema %}
