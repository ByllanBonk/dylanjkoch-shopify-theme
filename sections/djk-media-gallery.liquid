{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="djk-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="djk-container">
    <div class="djk-section-head{% if section.settings.center_head %} djk-section-head--center{% endif %} djk-reveal">
      {%- if section.settings.eyebrow != blank -%}
        <p class="djk-eyebrow djk-eyebrow--gold">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="djk-heading djk-heading--lg">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="djk-lead">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="djk-gallery__grid">
      {%- for block in section.blocks -%}
        <div
          class="djk-gallery__item{% if block.settings.wide %} djk-gallery__item--wide{% endif %} djk-reveal"
          style="--djk-delay: {{ forloop.index0 | times: 0.06 }}s;"
          {{ block.shopify_attributes }}
        >
          {%- case block.type -%}
            {%- when 'video' -%}
              {%- if block.settings.video_url != blank -%}
                {%- if block.settings.video_url.type == 'youtube' -%}
                  <iframe
                    src="https://www.youtube.com/embed/{{ block.settings.video_url.id }}?rel=0&modestbranding=1"
                    title="{{ block.settings.caption | default: 'Video' | escape }}"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                    loading="lazy"
                  ></iframe>
                {%- elsif block.settings.video_url.type == 'vimeo' -%}
                  <iframe
                    src="https://player.vimeo.com/video/{{ block.settings.video_url.id }}"
                    title="{{ block.settings.caption | default: 'Video' | escape }}"
                    allow="autoplay; fullscreen; picture-in-picture"
                    allowfullscreen
                    loading="lazy"
                  ></iframe>
                {%- endif -%}
              {%- else -%}
                <div class="djk-media-placeholder" style="position: absolute; inset: 0;">
                  <span>Add a video URL</span>
                </div>
              {%- endif -%}
            {%- else -%}
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 1200
                  | image_tag: loading: 'lazy', widths: '400, 600, 900, 1200', sizes: '(min-width: 990px) 33vw, 100vw'
                }}
              {%- else -%}
                <div class="djk-media-placeholder" style="position: absolute; inset: 0;">
                  <span>Add a photo</span>
                </div>
              {%- endif -%}
              {%- if block.settings.caption != blank -%}
                <span class="djk-gallery__caption">{{ block.settings.caption }}</span>
              {%- endif -%}
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "DJK Media Gallery",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Media"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Watch and listen"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text"
    },
    {
      "type": "checkbox",
      "id": "center_head",
      "label": "Center the heading",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "video_url",
          "id": "video_url",
          "label": "Video URL",
          "accept": ["youtube", "vimeo"]
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "checkbox",
          "id": "wide",
          "label": "Double width on desktop",
          "default": false
        }
      ]
    },
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "checkbox",
          "id": "wide",
          "label": "Double width on desktop",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DJK Media Gallery",
      "blocks": [
        { "type": "video", "settings": { "wide": true } },
        { "type": "photo" },
        { "type": "photo" },
        { "type": "photo" }
      ]
    }
  ]
}
{% endschema %}
