{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="djk-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"{% if section.settings.anchor_id != blank %} id="{{ section.settings.anchor_id }}"{% endif %}>
  <div class="djk-container">
    <div class="djk-section-head djk-section-head--center djk-reveal">
      {%- if section.settings.eyebrow != blank -%}
        <p class="djk-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="djk-heading djk-heading--lg">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="djk-lead">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="djk-ccards__grid">
      {%- for block in section.blocks -%}
        <div
          class="djk-card djk-card--hover djk-ccard{% if block.settings.wide %} djk-ccard--wide{% endif %}{% if block.settings.gold %} djk-ccard--gold{% endif %} djk-reveal"
          style="--djk-delay: {{ forloop.index0 | times: 0.06 }}s;"
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.kicker != blank -%}
            <span class="djk-chip {% if block.settings.gold %}djk-chip--gold{% else %}djk-chip--accent{% endif %} djk-ccard__kicker">{{ block.settings.kicker }}</span>
          {%- endif -%}

          <h3 class="djk-ccard__title">{{ block.settings.title }}</h3>

          {%- if block.settings.items != blank -%}
            <ul class="djk-ccard__list">
              {%- assign lines = block.settings.items | newline_to_br | split: '<br />' -%}
              {%- for line in lines -%}
                {%- assign trimmed = line | strip -%}
                {%- if trimmed != blank -%}
                  <li>{{ trimmed }}</li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "DJK Content Cards",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "info": "Optional. Lets buttons link straight to this section."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "What's Inside"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The complete system, part by part"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Content card",
      "settings": [
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker",
          "default": "Part 01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "The New Music Industry"
        },
        {
          "type": "textarea",
          "id": "items",
          "label": "Bullet points",
          "info": "One per line.",
          "default": "Why the gatekeeper era is over\nWhy audience ownership matters\nWhat direct-to-fan actually means"
        },
        {
          "type": "checkbox",
          "id": "wide",
          "label": "Full width on desktop",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "gold",
          "label": "Gold accent",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DJK Content Cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "kicker": "Part 01",
            "title": "The New Music Industry",
            "items": "Why the gatekeeper era is over\nWhy audience ownership matters\nWhat direct-to-fan actually means",
            "wide": true
          }
        },
        {
          "type": "card",
          "settings": {
            "kicker": "Part 02",
            "title": "Attract",
            "items": "Platform selection\nContent strategy\nAudience targeting\nHooks that earn attention"
          }
        },
        {
          "type": "card",
          "settings": {
            "kicker": "Part 03",
            "title": "Connect",
            "items": "Lead magnets\nLanding pages\nBuilding your list\nOwning the relationship"
          }
        }
      ]
    }
  ]
}
{% endschema %}
