{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="djk-section djk-grid-texture color-{{ section.settings.color_scheme }} gradient">
  <div class="djk-aurora"></div>

  <div class="djk-hero{% if section.settings.full_height %} djk-hero--full{% endif %} section-{{ section.id }}-padding">
    <div class="djk-container djk-hero__inner">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="djk-eyebrow djk-reveal">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class="djk-heading djk-heading--xl djk-reveal" style="--djk-delay: 0.08s;">
            {{ section.settings.heading }}
            {%- if section.settings.heading_highlight != blank %}
              <span class="djk-text-accent">{{ section.settings.heading_highlight }}</span>
            {%- endif -%}
          </h1>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <div class="djk-lead djk-hero__sub djk-reveal" style="--djk-delay: 0.16s;">
            {{ section.settings.subheading }}
          </div>
        {%- endif -%}

        <div class="djk-btn-row djk-reveal" style="--djk-delay: 0.24s;">
          {%- if section.settings.button_primary_text != blank -%}
            <a href="{{ section.settings.button_primary_link | default: '#' }}" class="djk-btn djk-btn--primary">
              {{ section.settings.button_primary_text }}
            </a>
          {%- endif -%}
          {%- if section.settings.button_secondary_text != blank -%}
            <a href="{{ section.settings.button_secondary_link | default: '#' }}" class="djk-btn djk-btn--ghost">
              {{ section.settings.button_secondary_text }}
            </a>
          {%- endif -%}
        </div>

        {%- if section.blocks.size > 0 -%}
          <div class="djk-hero__proof djk-reveal" style="--djk-delay: 0.32s;">
            {%- for block in section.blocks -%}
              <span class="djk-chip" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- if section.settings.show_visual -%}
        <div class="djk-reveal" style="--djk-delay: 0.2s;">
          <div class="djk-signal" aria-hidden="true">
            <div class="djk-signal__title">
              <span>{{ section.settings.visual_title | default: 'Direct-To-Fan Signal' }}</span>
              <span class="djk-signal__eq"><span></span><span></span><span></span><span></span></span>
            </div>

            <div style="position: relative;">
              <svg class="djk-signal__svg" viewBox="0 0 460 340" xmlns="http://www.w3.org/2000/svg">
                <path class="flow-base" d="M60 60 C 140 60, 160 170, 230 170" />
                <path class="flow-line" d="M60 60 C 140 60, 160 170, 230 170" />
                <path class="flow-base" d="M60 170 L 230 170" />
                <path class="flow-line" d="M60 170 L 230 170" style="animation-delay: 0.6s;" />
                <path class="flow-base" d="M60 280 C 140 280, 160 170, 230 170" />
                <path class="flow-line" d="M60 280 C 140 280, 160 170, 230 170" style="animation-delay: 1.1s;" />
                <path class="flow-base" d="M230 170 C 310 170, 320 60, 400 60" />
                <path class="flow-line flow-line--gold" d="M230 170 C 310 170, 320 60, 400 60" />
                <path class="flow-base" d="M230 170 L 400 170" />
                <path class="flow-line flow-line--gold" d="M230 170 L 400 170" style="animation-delay: 0.8s;" />
                <path class="flow-base" d="M230 170 C 310 170, 320 280, 400 280" />
                <path class="flow-line flow-line--gold" d="M230 170 C 310 170, 320 280, 400 280" style="animation-delay: 1.4s;" />
              </svg>

              <span class="djk-signal__node" style="top: 9%; left: 0;">
                <span class="djk-signal__node-dot"></span>{{ section.settings.node_in_1 | default: 'Your Music' }}
              </span>
              <span class="djk-signal__node" style="top: 44%; left: 0;">
                <span class="djk-signal__node-dot"></span>{{ section.settings.node_in_2 | default: 'Your Content' }}
              </span>
              <span class="djk-signal__node" style="top: 79%; left: 0;">
                <span class="djk-signal__node-dot"></span>{{ section.settings.node_in_3 | default: 'Your Story' }}
              </span>

              <span class="djk-signal__hub">{{ section.settings.hub_label | default: 'Owned Audience' }}</span>

              <span class="djk-signal__node djk-signal__node--gold" style="top: 9%; right: 0;">
                <span class="djk-signal__node-dot"></span>{{ section.settings.node_out_1 | default: 'Real Fans' }}
              </span>
              <span class="djk-signal__node djk-signal__node--gold" style="top: 44%; right: 0;">
                <span class="djk-signal__node-dot"></span>{{ section.settings.node_out_2 | default: 'Email List' }}
              </span>
              <span class="djk-signal__node djk-signal__node--gold" style="top: 79%; right: 0;">
                <span class="djk-signal__node-dot"></span>{{ section.settings.node_out_3 | default: 'Revenue' }}
              </span>
            </div>

            <div class="djk-signal__stats">
              <div>
                <div class="djk-signal__stat-value">{{ section.settings.stat_1_value | default: '100%' }}</div>
                <div class="djk-signal__stat-label">{{ section.settings.stat_1_label | default: 'Owned' }}</div>
              </div>
              <div>
                <div class="djk-signal__stat-value">{{ section.settings.stat_2_value | default: '0' }}</div>
                <div class="djk-signal__stat-label">{{ section.settings.stat_2_label | default: 'Algorithms' }}</div>
              </div>
              <div>
                <div class="djk-signal__stat-value">{{ section.settings.stat_3_value | default: '1:1' }}</div>
                <div class="djk-signal__stat-label">{{ section.settings.stat_3_label | default: 'Fan Access' }}</div>
              </div>
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.show_scroll_cue and section.settings.full_height -%}
      <a class="djk-hero__scroll" href="#djk-after-hero" aria-label="Scroll to content">
        <span>Scroll</span>
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M8 2v12m0 0l-5-5m5 5l5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    {%- endif -%}
  </div>
</div>
<span id="djk-after-hero"></span>

{% schema %}
{
  "name": "DJK Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "full_height",
      "label": "Full viewport height",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Drummer. Educator. Strategist."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Headline",
      "default": "Helping Musicians Build Direct-To-Fan Systems That Turn Attention Into"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Highlighted headline ending",
      "info": "Rendered in the accent gradient after the headline.",
      "default": "Fans, Email Subscribers, and Revenue"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheadline",
      "default": "<p>I'm Dylan Koch. Professional drummer, educator, and direct-to-fan strategist. I help musicians build audience, content, email, and revenue systems they actually own.</p>"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_primary_text",
      "label": "Primary button text",
      "default": "Get The Playbook"
    },
    {
      "type": "url",
      "id": "button_primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_secondary_text",
      "label": "Secondary button text",
      "default": "Book A Strategy Call"
    },
    {
      "type": "url",
      "id": "button_secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Signal flow visual",
      "info": "The animated diagram on the right side. Every label is editable."
    },
    {
      "type": "checkbox",
      "id": "show_visual",
      "label": "Show signal flow visual",
      "default": true
    },
    {
      "type": "text",
      "id": "visual_title",
      "label": "Visual title",
      "default": "Direct-To-Fan Signal"
    },
    {
      "type": "text",
      "id": "hub_label",
      "label": "Center hub label",
      "default": "Owned Audience"
    },
    {
      "type": "text",
      "id": "node_in_1",
      "label": "Input node 1",
      "default": "Your Music"
    },
    {
      "type": "text",
      "id": "node_in_2",
      "label": "Input node 2",
      "default": "Your Content"
    },
    {
      "type": "text",
      "id": "node_in_3",
      "label": "Input node 3",
      "default": "Your Story"
    },
    {
      "type": "text",
      "id": "node_out_1",
      "label": "Output node 1",
      "default": "Real Fans"
    },
    {
      "type": "text",
      "id": "node_out_2",
      "label": "Output node 2",
      "default": "Email List"
    },
    {
      "type": "text",
      "id": "node_out_3",
      "label": "Output node 3",
      "default": "Revenue"
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "Stat 1 value",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label",
      "default": "Owned"
    },
    {
      "type": "text",
      "id": "stat_2_value",
      "label": "Stat 2 value",
      "default": "0"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label",
      "default": "Algorithms"
    },
    {
      "type": "text",
      "id": "stat_3_value",
      "label": "Stat 3 value",
      "default": "1:1"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 label",
      "default": "Fan Access"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_cue",
      "label": "Show scroll cue",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "proof",
      "name": "Proof chip",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "20+ years behind the kit"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "DJK Hero",
      "blocks": [
        { "type": "proof", "settings": { "text": "20+ years behind the kit" } },
        { "type": "proof", "settings": { "text": "Toured North America and Europe" } },
        { "type": "proof", "settings": { "text": "Direct-to-fan strategist" } }
      ]
    }
  ]
}
{% endschema %}
