{%- liquid
  assign overlay = section.settings.overlay_strength | divided_by: 100.0
-%}
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="djk-section djk-hero-wrap color-{{ section.settings.color_scheme }} gradient">
  <div
    class="djk-hero-bg{% unless section.settings.hero_image %} djk-hero-bg--empty djk-grid-texture{% endunless %}"
    style="--djk-hero-focal: {{ section.settings.image_position }}; --djk-hero-focal-mobile: {{ section.settings.image_position_mobile }};"
  >
    {%- if section.settings.hero_image != blank -%}
      {{
        section.settings.hero_image
        | image_url: width: 2400
        | image_tag: loading: 'eager', fetchpriority: 'high', widths: '750, 1100, 1500, 1900, 2400', sizes: '100vw', class: 'djk-hero-bg__img', alt: section.settings.hero_image.alt | default: 'Dylan J Koch'
      }}
    {%- else -%}
      <div class="djk-aurora"></div>
      <div class="djk-media-placeholder djk-hero-bg__hint">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M4 16l4.6-4.6a2 2 0 012.8 0L16 16m-2-2l1.6-1.6a2 2 0 012.8 0L20 14M4 6h16a1 1 0 011 1v10a1 1 0 01-1 1H4a1 1 0 01-1-1V7a1 1 0 011-1zm10 3h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span>Add a hero background image in the theme editor</span>
      </div>
    {%- endif -%}
  </div>

  <div class="djk-hero-bg__scrim" style="--djk-hero-overlay: {{ overlay }};"></div>

  <div class="djk-hero djk-hero--bg{% if section.settings.full_height %} djk-hero--full{% endif %} section-{{ section.id }}-padding">
    <div class="djk-container">
      <div class="djk-hero__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="djk-eyebrow djk-reveal">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class="djk-heading djk-heading--xl djk-reveal" style="--djk-delay: 0.08s;">
            {{ section.settings.heading }}
            {%- if section.settings.heading_highlight != blank %}
              <span class="djk-text-accent">{{ section.settings.heading_highlight }}</span>
            {%- endif -%}
          </h1>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <div class="djk-lead djk-hero__sub djk-reveal" style="--djk-delay: 0.16s;">
            {{ section.settings.subheading }}
          </div>
        {%- endif -%}

        <div class="djk-btn-row djk-reveal" style="--djk-delay: 0.24s;">
          {%- if section.settings.button_primary_text != blank -%}
            <a href="{{ section.settings.button_primary_link | default: '#' }}" class="djk-btn djk-btn--primary">
              {{ section.settings.button_primary_text }}
            </a>
          {%- endif -%}
          {%- if section.settings.button_secondary_text != blank -%}
            <a href="{{ section.settings.button_secondary_link | default: '#' }}" class="djk-btn djk-btn--ghost">
              {{ section.settings.button_secondary_text }}
            </a>
          {%- endif -%}
        </div>

        {%- if section.blocks.size > 0 -%}
          <div class="djk-hero__proof djk-reveal" style="--djk-delay: 0.32s;">
            {%- for block in section.blocks -%}
              <span class="djk-chip" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- if section.settings.show_scroll_cue and section.settings.full_height -%}
      <a class="djk-hero__scroll" href="#djk-after-hero" aria-label="Scroll to content">
        <span>Scroll</span>
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M8 2v12m0 0l-5-5m5 5l5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    {%- endif -%}
  </div>
</div>
<span id="djk-after-hero"></span>

{% schema %}
{
  "name": "DJK Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "full_height",
      "label": "Full viewport height",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Professional Drummer • Music Marketer"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Headline",
      "default": "Build An Audience You"
    },
    {
      "type": "text",
      "id": "heading_highlight",
      "label": "Highlighted headline ending",
      "info": "Rendered in the accent gradient after the headline.",
      "default": "Actually Own"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheadline",
      "default": "<p>I've spent 20+ years on stages and in studios.</p><p>Now I help musicians grow their audience, attract more fans, and create more opportunities to earn from their music.</p>"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_primary_text",
      "label": "Primary button text",
      "default": "Get The Playbook"
    },
    {
      "type": "url",
      "id": "button_primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_secondary_text",
      "label": "Secondary button text",
      "default": "Book A Strategy Intensive"
    },
    {
      "type": "url",
      "id": "button_secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "Hero background image",
      "info": "A full width photograph sits behind the text. Portrait or live performance shots both work. The text stays on the left with a dark overlay for readability."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero background image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image focus (desktop)",
      "options": [
        { "value": "left center", "label": "Left" },
        { "value": "center top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "right center", "label": "Right" }
      ],
      "default": "right center"
    },
    {
      "type": "select",
      "id": "image_position_mobile",
      "label": "Image focus (mobile)",
      "options": [
        { "value": "left center", "label": "Left" },
        { "value": "center top", "label": "Top" },
        { "value": "center", "label": "Center" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "right center", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "overlay_strength",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Dark overlay strength",
      "info": "Higher keeps text readable. Lower lets more of the photo show through.",
      "default": 70
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_cue",
      "label": "Show scroll cue",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "proof",
      "name": "Proof chip",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "20+ Years Behind The Kit"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "DJK Hero",
      "blocks": [
        { "type": "proof", "settings": { "text": "20+ Years Behind The Kit" } },
        { "type": "proof", "settings": { "text": "Toured North America & Europe" } },
        { "type": "proof", "settings": { "text": "Audience Growth Systems" } }
      ]
    }
  ]
}
{% endschema %}
