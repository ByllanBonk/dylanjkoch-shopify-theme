{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="djk-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="djk-container">
    <div class="djk-section-head djk-section-head--center djk-reveal">
      {%- if section.settings.eyebrow != blank -%}
        <p class="djk-eyebrow djk-eyebrow--gold">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="djk-heading djk-heading--lg">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="djk-lead">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="djk-testimonials__grid{% if section.settings.columns == '3' %} djk-testimonials__grid--three{% endif %}">
      {%- for block in section.blocks -%}
        <figure class="djk-card djk-card--hover djk-testimonial djk-reveal" style="--djk-delay: {{ forloop.index0 | times: 0.08 }}s;" {{ block.shopify_attributes }}>
          {%- if section.settings.show_stars -%}
            <span class="djk-testimonial__stars" aria-hidden="true">
              {%- for i in (1..5) -%}
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M8 1.5l1.9 3.9 4.3.6-3.1 3 .7 4.3L8 11.3l-3.8 2 .7-4.3-3.1-3 4.3-.6L8 1.5z"/></svg>
              {%- endfor -%}
            </span>
          {%- endif -%}

          <blockquote class="djk-testimonial__quote">{{ block.settings.quote }}</blockquote>

          <figcaption class="djk-testimonial__person">
            <span class="djk-testimonial__avatar" aria-hidden="true">
              {%- if block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 120 | image_tag: loading: 'lazy', alt: '' }}
              {%- else -%}
                {{ block.settings.name | slice: 0, 1 | default: '?' }}
              {%- endif -%}
            </span>
            <span>
              <span class="djk-testimonial__name">{{ block.settings.name }}</span><br>
              {%- if block.settings.role != blank -%}
                <span class="djk-testimonial__role">{{ block.settings.role }}</span>
              {%- endif -%}
            </span>
          </figcaption>
        </figure>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "DJK Testimonials",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Kind Words"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From people I have worked with"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text"
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show star ratings",
      "default": false
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "Two" },
        { "value": "3", "label": "Three" }
      ],
      "default": "3"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Add a short quote from a student, client, or collaborator here."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "First Last"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role or project",
          "default": "Independent artist"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DJK Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
