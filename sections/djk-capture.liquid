{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="djk-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"{% if section.settings.anchor_id != blank %} id="{{ section.settings.anchor_id }}"{% endif %}>
  <div class="djk-container">
    <div class="djk-capture__card djk-reveal">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="djk-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="djk-heading djk-heading--lg">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="djk-lead">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <ul class="djk-magnet__list">
            {%- for block in section.blocks -%}
              <li {{ block.shopify_attributes }}>
                <span class="djk-magnet__check" aria-hidden="true">
                  <svg width="11" height="11" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2.5 8.5l3.5 3.5L13.5 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      <div>
        {% render 'djk-capture-fields', s: section.settings, form_id: section.id %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "DJK Capture Form",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "info": "Lets buttons link straight to this section, for example #get-the-playbook.",
      "default": "get-the-playbook"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Free Download"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get The Direct-To-Fan Playbook"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Enter your details and the Playbook lands in your inbox.</p>"
    },
    {
      "type": "header",
      "content": "Fields"
    },
    {
      "type": "checkbox",
      "id": "show_name",
      "label": "Show first name field",
      "default": true
    },
    {
      "type": "text",
      "id": "name_label",
      "label": "First name label",
      "default": "First name"
    },
    {
      "type": "text",
      "id": "name_placeholder",
      "label": "First name placeholder",
      "default": "Your first name"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "you@example.com"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Show phone field (SMS)",
      "default": true
    },
    {
      "type": "text",
      "id": "phone_label",
      "label": "Phone label",
      "default": "Phone (optional)"
    },
    {
      "type": "text",
      "id": "phone_placeholder",
      "label": "Phone placeholder",
      "default": "For SMS updates"
    },
    {
      "type": "header",
      "content": "Consent and compliance"
    },
    {
      "type": "inline_richtext",
      "id": "consent_text",
      "label": "Consent checkbox text",
      "default": "I agree to receive email and SMS updates. Message and data rates may apply. Unsubscribe or reply STOP at any time."
    },
    {
      "type": "checkbox",
      "id": "require_consent",
      "label": "Require consent to submit",
      "default": true
    },
    {
      "type": "richtext",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "<p>No spam. Your information is never sold or shared.</p>"
    },
    {
      "type": "text",
      "id": "compliance_text",
      "label": "Compliance line",
      "default": "By submitting, you agree to the privacy policy."
    },
    {
      "type": "header",
      "content": "Button and messages"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Send Me The Playbook"
    },
    {
      "type": "text",
      "id": "success_text",
      "label": "Success message",
      "default": "You're in. Check your inbox for the Playbook."
    },
    {
      "type": "richtext",
      "id": "thank_you_text",
      "label": "Thank you copy",
      "default": "<p>If you do not see the email within a few minutes, check your spam or promotions folder.</p>"
    },
    {
      "type": "header",
      "content": "Email platform",
      "info": "Theme default follows Theme settings, Dylan Koch brand, Lead capture platform (Shopify customers or Klaviyo direct). Custom mode posts to any other platform form endpoint."
    },
    {
      "type": "select",
      "id": "form_mode",
      "label": "Form mode",
      "options": [
        { "value": "shopify", "label": "Theme default (Shopify or Klaviyo)" },
        { "value": "custom", "label": "Custom endpoint (MailerLite, other)" }
      ],
      "default": "shopify"
    },
    {
      "type": "text",
      "id": "subscriber_tag",
      "label": "Subscriber tag",
      "info": "Shopify customer tag, also sent to Klaviyo as the signup source.",
      "default": "playbook"
    },
    {
      "type": "text",
      "id": "custom_action",
      "label": "Custom form action URL",
      "info": "Custom mode only. Paste the form endpoint from your email platform."
    },
    {
      "type": "text",
      "id": "custom_name_field",
      "label": "Custom name field attribute",
      "default": "fields[name]"
    },
    {
      "type": "text",
      "id": "custom_email_field",
      "label": "Custom email field attribute",
      "default": "fields[email]"
    },
    {
      "type": "text",
      "id": "custom_phone_field",
      "label": "Custom phone field attribute",
      "default": "fields[phone]"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Bullet",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Text",
          "default": "What you get when you sign up"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "DJK Capture Form",
      "blocks": [
        { "type": "bullet", "settings": { "text": "The complete Direct-To-Fan Playbook" } },
        { "type": "bullet", "settings": { "text": "The ACEMM framework explained step by step" } },
        { "type": "bullet", "settings": { "text": "Occasional emails with practical strategy" } }
      ]
    }
  ]
}
{% endschema %}
