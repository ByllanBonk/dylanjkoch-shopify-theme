{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .djk-signal-section__inner {
    display: grid;
    gap: 4.5rem;
    align-items: center;
    width: 100%;
  }

  @media screen and (min-width: 990px) {
    .djk-signal-section__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 6rem;
    }
  }

  .djk-signal-section__copy {
    margin-top: 2.4rem;
  }
{%- endstyle -%}

<div class="djk-section djk-grid-texture color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"{% if section.settings.anchor_id != blank %} id="{{ section.settings.anchor_id }}"{% endif %}>
  <div class="djk-aurora"></div>
  <div class="djk-container" style="position: relative;">
    <div class="djk-signal-section__inner">
      <div class="djk-reveal">
        {%- if section.settings.eyebrow != blank -%}
          <p class="djk-eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="djk-heading djk-heading--lg">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="djk-lead">{{ section.settings.text }}</div>
        {%- endif -%}
        {%- if section.settings.copy != blank -%}
          <div class="djk-signal-section__copy">{{ section.settings.copy }}</div>
        {%- endif -%}
        {%- if section.settings.button_text != blank -%}
          <div class="djk-btn-row" style="margin-top: 3rem;">
            <a href="{{ section.settings.button_link | default: '#' }}" class="djk-btn djk-btn--primary">{{ section.settings.button_text }}</a>
          </div>
        {%- endif -%}
      </div>

      <div class="djk-reveal" style="--djk-delay: 0.16s;">
        <div class="djk-signal" aria-hidden="true">
          <div class="djk-signal__title">
            <span>{{ section.settings.visual_title | default: 'Direct-To-Fan Signal' }}</span>
            <span class="djk-signal__eq"><span></span><span></span><span></span><span></span></span>
          </div>

          <div style="position: relative;">
            <svg class="djk-signal__svg" viewBox="0 0 460 340" xmlns="http://www.w3.org/2000/svg">
              <path class="flow-base" d="M60 60 C 140 60, 160 170, 230 170" />
              <path class="flow-line" d="M60 60 C 140 60, 160 170, 230 170" />
              <path class="flow-base" d="M60 170 L 230 170" />
              <path class="flow-line" d="M60 170 L 230 170" style="animation-delay: 0.6s;" />
              <path class="flow-base" d="M60 280 C 140 280, 160 170, 230 170" />
              <path class="flow-line" d="M60 280 C 140 280, 160 170, 230 170" style="animation-delay: 1.1s;" />
              <path class="flow-base" d="M230 170 C 310 170, 320 60, 400 60" />
              <path class="flow-line flow-line--gold" d="M230 170 C 310 170, 320 60, 400 60" />
              <path class="flow-base" d="M230 170 L 400 170" />
              <path class="flow-line flow-line--gold" d="M230 170 L 400 170" style="animation-delay: 0.8s;" />
              <path class="flow-base" d="M230 170 C 310 170, 320 280, 400 280" />
              <path class="flow-line flow-line--gold" d="M230 170 C 310 170, 320 280, 400 280" style="animation-delay: 1.4s;" />
            </svg>

            <span class="djk-signal__node" style="top: 9%; left: 0;">
              <span class="djk-signal__node-dot"></span>{{ section.settings.node_in_1 | default: 'Your Music' }}
            </span>
            <span class="djk-signal__node" style="top: 44%; left: 0;">
              <span class="djk-signal__node-dot"></span>{{ section.settings.node_in_2 | default: 'Your Content' }}
            </span>
            <span class="djk-signal__node" style="top: 79%; left: 0;">
              <span class="djk-signal__node-dot"></span>{{ section.settings.node_in_3 | default: 'Your Story' }}
            </span>

            <span class="djk-signal__hub">{{ section.settings.hub_label | default: 'Owned Audience' }}</span>

            <span class="djk-signal__node djk-signal__node--gold" style="top: 9%; right: 0;">
              <span class="djk-signal__node-dot"></span>{{ section.settings.node_out_1 | default: 'Real Fans' }}
            </span>
            <span class="djk-signal__node djk-signal__node--gold" style="top: 44%; right: 0;">
              <span class="djk-signal__node-dot"></span>{{ section.settings.node_out_2 | default: 'Email List' }}
            </span>
            <span class="djk-signal__node djk-signal__node--gold" style="top: 79%; right: 0;">
              <span class="djk-signal__node-dot"></span>{{ section.settings.node_out_3 | default: 'Revenue' }}
            </span>
          </div>

          <div class="djk-signal__stats">
            <div>
              <div class="djk-signal__stat-value">{{ section.settings.stat_1_value | default: '100%' }}</div>
              <div class="djk-signal__stat-label">{{ section.settings.stat_1_label | default: 'Owned' }}</div>
            </div>
            <div>
              <div class="djk-signal__stat-value">{{ section.settings.stat_2_value | default: '0' }}</div>
              <div class="djk-signal__stat-label">{{ section.settings.stat_2_label | default: 'Algorithms' }}</div>
            </div>
            <div>
              <div class="djk-signal__stat-value">{{ section.settings.stat_3_value | default: '1:1' }}</div>
              <div class="djk-signal__stat-label">{{ section.settings.stat_3_label | default: 'Fan Access' }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "DJK Signal Flow",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID",
      "info": "Optional. Lets buttons link straight to this section."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The System"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How Attention Becomes Opportunity"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text",
      "default": "<p>Every musician starts with attention. The question is what you do with it.</p>"
    },
    {
      "type": "richtext",
      "id": "copy",
      "label": "Supporting copy",
      "default": "<p>Your music, your content, and your story pull people in. Instead of leaving that attention on rented platforms, you move it onto channels you own.</p><p>That is where fans, email subscribers, and revenue come from. One audience, owned, working for you around the clock.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Get The Playbook"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Signal labels",
      "info": "Every label on the animated graphic is editable."
    },
    {
      "type": "text",
      "id": "visual_title",
      "label": "Visual title",
      "default": "Direct-To-Fan Signal"
    },
    {
      "type": "text",
      "id": "hub_label",
      "label": "Center hub label",
      "default": "Owned Audience"
    },
    {
      "type": "text",
      "id": "node_in_1",
      "label": "Input node 1",
      "default": "Your Music"
    },
    {
      "type": "text",
      "id": "node_in_2",
      "label": "Input node 2",
      "default": "Your Content"
    },
    {
      "type": "text",
      "id": "node_in_3",
      "label": "Input node 3",
      "default": "Your Story"
    },
    {
      "type": "text",
      "id": "node_out_1",
      "label": "Output node 1",
      "default": "Real Fans"
    },
    {
      "type": "text",
      "id": "node_out_2",
      "label": "Output node 2",
      "default": "Email List"
    },
    {
      "type": "text",
      "id": "node_out_3",
      "label": "Output node 3",
      "default": "Revenue"
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "Stat 1 value",
      "default": "100%"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 label",
      "default": "Owned"
    },
    {
      "type": "text",
      "id": "stat_2_value",
      "label": "Stat 2 value",
      "default": "0"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 label",
      "default": "Algorithms"
    },
    {
      "type": "text",
      "id": "stat_3_value",
      "label": "Stat 3 value",
      "default": "1:1"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 label",
      "default": "Fan Access"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 96
    }
  ],
  "presets": [
    {
      "name": "DJK Signal Flow"
    }
  ]
}
{% endschema %}
