{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="djk-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="djk-container">
    <div class="djk-music__inner">
      <div class="djk-reveal">
        <div class="djk-music__media">
          {%- if section.settings.badge_text != blank -%}
            <span class="djk-chip djk-chip--gold djk-music__media-badge">{{ section.settings.badge_text }}</span>
          {%- endif -%}
          {%- if section.settings.video_url != blank -%}
            {%- if section.settings.video_url.type == 'youtube' -%}
              <iframe
                src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?rel=0&modestbranding=1"
                title="{{ section.settings.heading | escape }}"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            {%- elsif section.settings.video_url.type == 'vimeo' -%}
              <iframe
                src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}"
                title="{{ section.settings.heading | escape }}"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            {%- endif -%}
          {%- elsif section.settings.image != blank -%}
            {{
              section.settings.image
              | image_url: width: 1600
              | image_tag: loading: 'lazy', widths: '550, 720, 990, 1400, 1600', sizes: '(min-width: 990px) 55vw, 100vw'
            }}
          {%- else -%}
            <div class="djk-media-placeholder" style="position: absolute; inset: 0;">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><ellipse cx="12" cy="7.5" rx="9" ry="3.5" stroke="currentColor" stroke-width="1.5"/><path d="M3 7.5V16c0 1.9 4 3.5 9 3.5s9-1.6 9-3.5V7.5" stroke="currentColor" stroke-width="1.5"/></svg>
              <span>Add a performance photo or video URL</span>
            </div>
          {%- endif -%}
        </div>
      </div>

      <div class="djk-music__panel">
        {%- if section.settings.eyebrow != blank -%}
          <p class="djk-eyebrow djk-eyebrow--gold djk-reveal">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="djk-heading djk-heading--lg djk-reveal" style="--djk-delay: 0.08s;">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="djk-lead djk-reveal" style="--djk-delay: 0.14s;">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="djk-music__highlights">
            {%- for block in section.blocks -%}
              <div class="djk-card djk-music-highlight djk-reveal" style="--djk-delay: {{ forloop.index0 | times: 0.07 | plus: 0.18 }}s;" {{ block.shopify_attributes }}>
                <span class="djk-music-highlight__icon" aria-hidden="true">
                  {%- case block.settings.icon -%}
                    {%- when 'globe' -%}
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><path d="M3 12h18M12 3c2.5 2.6 3.8 5.7 3.8 9S14.5 18.4 12 21c-2.5-2.6-3.8-5.7-3.8-9S9.5 5.6 12 3z" stroke="currentColor" stroke-width="1.5"/></svg>
                    {%- when 'record' -%}
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/><path d="M12 12h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                    {%- when 'teach' -%}
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 4L2 9l10 5 10-5-10-5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/><path d="M6 11.5V16c0 1.1 2.7 2.5 6 2.5s6-1.4 6-2.5v-4.5M22 9v5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    {%- else -%}
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><ellipse cx="12" cy="7.5" rx="9" ry="3.5" stroke="currentColor" stroke-width="1.5"/><path d="M3 7.5V16c0 1.9 4 3.5 9 3.5s9-1.6 9-3.5V7.5M7.5 10.4V19m9-8.6V19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  {%- endcase -%}
                </span>
                <span>
                  {%- if block.settings.label != blank -%}
                    <span class="djk-music-highlight__label">{{ block.settings.label }}</span>
                  {%- endif -%}
                  <span class="djk-music-highlight__title">{{ block.settings.title }}</span>
                  {%- if block.settings.text != blank -%}
                    <p class="djk-music-highlight__text">{{ block.settings.text }}</p>
                  {%- endif -%}
                </span>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.button_text != blank -%}
          <div class="djk-btn-row djk-reveal" style="--djk-delay: 0.3s;">
            <a href="{{ section.settings.button_link | default: '#' }}" class="djk-btn djk-btn--gold">{{ section.settings.button_text }}</a>
            {%- if section.settings.button_2_text != blank -%}
              <a href="{{ section.settings.button_2_link | default: '#' }}" class="djk-btn djk-btn--ghost">{{ section.settings.button_2_text }}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "DJK Featured Musician",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Media",
      "info": "A video URL takes priority over the image."
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Video URL",
      "accept": ["youtube", "vimeo"]
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Performance image"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Media badge",
      "default": "On Stage"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Musician"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Music came first. It still does."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Two decades of stages, studios, and students. The strategy work exists because the music demanded it.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Primary button text",
      "default": "Explore The Drumming"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Secondary button text"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Secondary button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "globe", "label": "Globe (touring)" },
            { "value": "record", "label": "Record (recording)" },
            { "value": "teach", "label": "Teaching" },
            { "value": "drum", "label": "Drum" }
          ],
          "default": "globe"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Touring"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "North America and Europe"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Years of club dates, festivals, and tours on both sides of the Atlantic."
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "DJK Featured Musician",
      "blocks": [
        {
          "type": "highlight",
          "settings": {
            "icon": "globe",
            "label": "Touring",
            "title": "North America and Europe",
            "text": "Years of club dates, festivals, and tours on both sides of the Atlantic."
          }
        },
        {
          "type": "highlight",
          "settings": {
            "icon": "record",
            "label": "Recording",
            "title": "Multiple albums and sessions",
            "text": "Studio records, session work, and remote tracking."
          }
        },
        {
          "type": "highlight",
          "settings": {
            "icon": "teach",
            "label": "Teaching",
            "title": "Lessons and clinics",
            "text": "Private students plus clinics for schools and programs."
          }
        }
      ]
    }
  ]
}
{% endschema %}
