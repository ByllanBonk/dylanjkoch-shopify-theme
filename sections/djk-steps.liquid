{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="djk-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="djk-container">
    <div class="djk-section-head djk-section-head--center djk-reveal">
      {%- if section.settings.eyebrow != blank -%}
        <p class="djk-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="djk-heading djk-heading--lg">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="djk-lead">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="djk-steps__row{% if section.blocks.size > 3 %} djk-steps__row--four{% endif %}">
      {%- for block in section.blocks -%}
        <div
          class="djk-card djk-card--hover djk-step{% if block.settings.gold %} djk-step--gold{% endif %} djk-reveal"
          style="--djk-delay: {{ forloop.index0 | times: 0.08 }}s;"
          {{ block.shopify_attributes }}
        >
          <span class="djk-step__num" aria-hidden="true">{{ forloop.index }}</span>
          <h3 class="djk-step__title">{{ block.settings.title }}</h3>
          {%- if block.settings.text != blank -%}
            <p class="djk-step__text">{{ block.settings.text }}</p>
          {%- endif -%}
          {%- if block.settings.link_text != blank -%}
            <span class="djk-step__link">
              <a href="{{ block.settings.link | default: '#' }}" class="djk-btn djk-btn--link">{{ block.settings.link_text }}</a>
            </span>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "DJK Steps",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "What Happens Next"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Four moves from here"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Download The Playbook"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "gold",
          "label": "Gold accent",
          "default": false
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "DJK Steps",
      "blocks": [
        { "type": "step", "settings": { "title": "Download The Playbook", "text": "Get the Operating System and read it once, start to finish." } },
        { "type": "step", "settings": { "title": "Identify Your Bottlenecks", "text": "Use ACEMM to find the one stage holding your growth back." } },
        { "type": "step", "settings": { "title": "Implement The System", "text": "Follow the 90-day build order. One piece at a time." } },
        { "type": "step", "settings": { "title": "Book A Strategy Intensive", "text": "Want help applying it? We map your plan together in 90 minutes.", "link_text": "Learn more", "gold": true } }
      ]
    }
  ]
}
{% endschema %}
