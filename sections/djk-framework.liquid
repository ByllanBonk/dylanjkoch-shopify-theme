{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="djk-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="djk-container">
    <div class="djk-section-head djk-section-head--center djk-reveal">
      {%- if section.settings.eyebrow != blank -%}
        <p class="djk-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="djk-heading djk-heading--lg">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="djk-lead">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="djk-acc-list"{% if section.settings.single_open %} data-djk-single{% endif %}>
      {%- for block in section.blocks -%}
        <details
          class="djk-acc djk-reveal"
          style="--djk-delay: {{ forloop.index0 | times: 0.07 }}s;"
          {% if forloop.first and section.settings.open_first %}open{% endif %}
          {{ block.shopify_attributes }}
        >
          <summary>
            <span class="djk-acc__index" aria-hidden="true">
              {%- if block.settings.letter != blank -%}
                {{ block.settings.letter }}
              {%- else -%}
                {{ forloop.index }}
              {%- endif -%}
            </span>
            <span class="djk-acc__title">
              {{ block.settings.title }}
              {%- if block.settings.hint != blank -%}
                <span class="djk-acc__hint">{{ block.settings.hint }}</span>
              {%- endif -%}
            </span>
            <span class="djk-acc__chevron" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 6l5 5 5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </summary>
          <div class="djk-acc__body">
            {{ block.settings.content }}
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "DJK Framework",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The ACEMM Framework"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Five moves. One system."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text",
      "default": "<p>Every direct-to-fan system I build runs on the same five stages. Open each one to see how it works.</p>"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "label": "Open the first card by default",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "single_open",
      "label": "Only one card open at a time",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "letter",
          "label": "Badge letter or number",
          "info": "Leave blank to use the step number.",
          "default": "A"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Attract"
        },
        {
          "type": "text",
          "id": "hint",
          "label": "Short hint (desktop only)"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Describe this stage of the framework.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DJK Framework (ACEMM)",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "letter": "A",
            "title": "Attract",
            "content": "<p>Make content that pulls the right listeners toward your music. Not viral noise. Work that sounds like you and finds the people who will actually care.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "letter": "C",
            "title": "Connect",
            "content": "<p>Move attention off rented platforms and onto your list. A lead magnet, a clear offer, and a simple page that turns a listener into a subscriber.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "letter": "E",
            "title": "Engage",
            "content": "<p>Show up in the inbox with stories, music, and behind the scenes work that builds real trust. Consistency beats volume here.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "letter": "M",
            "title": "Monetize",
            "content": "<p>Offer things fans actually want. Music, merch, lessons, experiences, and digital products, sold direct so you keep the relationship and the margin.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "letter": "M",
            "title": "Multiply",
            "content": "<p>Turn happy fans into your loudest channel. Referrals, shares, and superfans who bring the next wave of listeners in with them.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
