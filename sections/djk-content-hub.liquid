{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="djk-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="djk-container">
    <div class="djk-section-head djk-section-head--center djk-reveal">
      {%- if section.settings.eyebrow != blank -%}
        <p class="djk-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="djk-heading djk-heading--lg">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="djk-lead">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    {%- assign has_filters = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'filter' -%}{%- assign has_filters = true -%}{%- endif -%}
    {%- endfor -%}
    {%- if has_filters -%}
      <div class="djk-hub__filters djk-reveal">
        {%- for block in section.blocks -%}
          {%- if block.type == 'filter' -%}
            <a href="{{ block.settings.link | default: '#' }}" class="djk-chip" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="djk-hub__grid">
      {%- comment -%} Custom resource cards first, then latest blog posts fill remaining slots. {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'filter' -%}{%- continue -%}{%- endif -%}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="djk-card djk-card--hover djk-hub-card{% if block.settings.featured %} djk-hub-card--featured{% endif %} djk-reveal"
          style="--djk-delay: {{ forloop.index0 | times: 0.08 }}s;"
          {{ block.shopify_attributes }}
        >
          <div class="djk-hub-card__media">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 900
                | image_tag: loading: 'lazy', widths: '400, 600, 900', sizes: '(min-width: 990px) 33vw, 100vw'
              }}
            {%- else -%}
              <div class="djk-media-placeholder" style="position: absolute; inset: 0;">
                <span>{{ block.settings.tag | default: 'Resource' }}</span>
              </div>
            {%- endif -%}
          </div>
          <div class="djk-hub-card__body">
            {%- if block.settings.tag != blank -%}
              <span class="djk-chip djk-chip--accent">{{ block.settings.tag }}</span>
            {%- endif -%}
            <h3 class="djk-hub-card__title">{{ block.settings.title }}</h3>
            {%- if block.settings.excerpt != blank -%}
              <p class="djk-hub-card__excerpt">{{ block.settings.excerpt }}</p>
            {%- endif -%}
            <span class="djk-hub-card__cta">{{ block.settings.cta | default: 'View' }} &rarr;</span>
          </div>
        </a>
      {%- endfor -%}

      {%- if section.settings.blog != blank -%}
        {%- assign remaining = section.settings.posts_to_show -%}
        {%- for article in section.settings.blog.articles limit: remaining -%}
          <a
            href="{{ article.url }}"
            class="djk-card djk-card--hover djk-hub-card djk-reveal"
            style="--djk-delay: {{ forloop.index0 | times: 0.08 }}s;"
          >
            <div class="djk-hub-card__media">
              {%- if article.image != blank -%}
                {{
                  article.image
                  | image_url: width: 900
                  | image_tag: loading: 'lazy', widths: '400, 600, 900', sizes: '(min-width: 990px) 33vw, 100vw'
                }}
              {%- else -%}
                <div class="djk-media-placeholder" style="position: absolute; inset: 0;">
                  <span>Article</span>
                </div>
              {%- endif -%}
            </div>
            <div class="djk-hub-card__body">
              <span class="djk-chip djk-chip--accent">{{ section.settings.blog_tag_label | default: 'Article' }}</span>
              <h3 class="djk-hub-card__title">{{ article.title }}</h3>
              <p class="djk-hub-card__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
              <span class="djk-hub-card__cta">Read &rarr;</span>
            </div>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.button_text != blank -%}
      <div class="djk-btn-row djk-btn-row--center djk-reveal">
        <a href="{{ section.settings.button_link | default: '#' }}" class="djk-btn djk-btn--ghost">{{ section.settings.button_text }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "DJK Content Hub",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Learn"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Videos, articles, and resources"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text",
      "default": "<p>Practical material on direct-to-fan strategy, content systems, and life as a working musician.</p>"
    },
    {
      "type": "header",
      "content": "Blog feed",
      "info": "Latest posts from this blog appear after your custom cards."
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "posts_to_show",
      "min": 0,
      "max": 9,
      "step": 1,
      "default": 3,
      "label": "Blog posts to show"
    },
    {
      "type": "text",
      "id": "blog_tag_label",
      "label": "Blog card tag label",
      "default": "Article"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Browse All Resources"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "resource",
      "name": "Resource card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Tag",
          "default": "Video"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Resource title"
        },
        {
          "type": "textarea",
          "id": "excerpt",
          "label": "Excerpt",
          "default": "A short description of what this resource covers and who it helps."
        },
        {
          "type": "text",
          "id": "cta",
          "label": "Link label",
          "default": "Watch"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Featured (wide card)",
          "default": false
        }
      ]
    },
    {
      "type": "filter",
      "name": "Category link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Videos"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Point at a blog, a tag, or any page."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DJK Content Hub",
      "blocks": [
        {
          "type": "resource",
          "settings": {
            "tag": "Video",
            "title": "How email beats the algorithm for working musicians",
            "excerpt": "Why your list is the most reliable channel you will ever build, and how to start one this week.",
            "cta": "Watch"
          }
        },
        {
          "type": "resource",
          "settings": {
            "tag": "Case Study",
            "title": "From casual listeners to a sold out release",
            "excerpt": "A walkthrough of the launch system, the emails, and what the numbers did.",
            "cta": "Read"
          }
        },
        {
          "type": "resource",
          "settings": {
            "tag": "Free Tool",
            "title": "The Direct-To-Fan Playbook",
            "excerpt": "The full framework in one download. Start here if you are new.",
            "cta": "Download"
          }
        }
      ]
    }
  ]
}
{% endschema %}
