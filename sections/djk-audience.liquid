{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="djk-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="djk-container">
    <div class="djk-section-head{% if section.settings.center_head %} djk-section-head--center{% endif %} djk-reveal">
      {%- if section.settings.eyebrow != blank -%}
        <p class="djk-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="djk-heading djk-heading--lg">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="djk-lead">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="djk-aud__grid{% if section.settings.columns == '3' %} djk-aud__grid--three{% endif %}">
      {%- for block in section.blocks -%}
        <div class="djk-card djk-card--hover djk-aud-card djk-reveal" style="--djk-delay: {{ forloop.index0 | times: 0.06 }}s;" {{ block.shopify_attributes }}>
          <span class="djk-aud-card__icon {% if block.settings.style == 'cross' %}djk-aud-card__icon--cross{% else %}djk-aud-card__icon--check{% endif %}" aria-hidden="true">
            {%- if block.settings.style == 'cross' -%}
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
            {%- else -%}
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2.5 8.5l3.5 3.5L13.5 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            {%- endif -%}
          </span>
          <span>
            <h3 class="djk-aud-card__title">{{ block.settings.title }}</h3>
            {%- if block.settings.text != blank -%}
              <p class="djk-aud-card__text">{{ block.settings.text }}</p>
            {%- endif -%}
          </span>
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.footline != blank -%}
      <div class="djk-compare__foot djk-reveal">
        <p>{{ section.settings.footline }}</p>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "DJK Audience Cards",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Who This Is For"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "This is for you if"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text"
    },
    {
      "type": "checkbox",
      "id": "center_head",
      "label": "Center the heading",
      "default": true
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "Two" },
        { "value": "3", "label": "Three" }
      ],
      "default": "2"
    },
    {
      "type": "text",
      "id": "footline",
      "label": "Closing line"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Card",
      "settings": [
        {
          "type": "select",
          "id": "style",
          "label": "Icon",
          "options": [
            { "value": "check", "label": "Check" },
            { "value": "cross", "label": "Cross" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Musicians posting content without clear results"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DJK Audience Cards",
      "blocks": [
        { "type": "item", "settings": { "title": "Musicians posting content without clear results" } },
        { "type": "item", "settings": { "title": "Artists trying to grow an email list" } },
        { "type": "item", "settings": { "title": "Creators overwhelmed by platforms" } },
        { "type": "item", "settings": { "title": "Artists wanting a direct relationship with fans" } }
      ]
    }
  ]
}
{% endschema %}
