{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="djk-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="djk-divider-glow"></div>
  <div class="djk-container">
    <div class="djk-section-head djk-section-head--center djk-reveal">
      {%- if section.settings.eyebrow != blank -%}
        <p class="djk-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="djk-heading djk-heading--lg">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="djk-lead">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="djk-compare__grid">
      <div class="djk-compare__panel djk-compare__panel--rented djk-reveal">
        <span class="djk-compare__label">{{ section.settings.rented_label }}</span>
        <h3 class="djk-compare__title">{{ section.settings.rented_title }}</h3>
        <ul class="djk-compare__list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'rented_item' -%}
              <li class="djk-compare__item" {{ block.shopify_attributes }}>
                <span class="djk-compare__icon" aria-hidden="true">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M3 3l10 10M13 3L3 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
                </span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      <div class="djk-compare__panel djk-compare__panel--owned djk-reveal" style="--djk-delay: 0.12s;">
        <span class="djk-compare__label">{{ section.settings.owned_label }}</span>
        <h3 class="djk-compare__title">{{ section.settings.owned_title }}</h3>
        <ul class="djk-compare__list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'owned_item' -%}
              <li class="djk-compare__item" {{ block.shopify_attributes }}>
                <span class="djk-compare__icon" aria-hidden="true">
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M2.5 8.5l3.5 3.5L13.5 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    </div>

    {%- if section.settings.footline != blank -%}
      <div class="djk-compare__foot djk-reveal">
        <p>{{ section.settings.footline }}</p>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "DJK Rented vs Owned",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Core Idea"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Rented Attention vs Owned Attention"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text",
      "default": "<p>Every musician builds on one of two foundations. Only one of them belongs to you.</p>"
    },
    {
      "type": "header",
      "content": "Rented panel"
    },
    {
      "type": "text",
      "id": "rented_label",
      "label": "Label",
      "default": "Rented"
    },
    {
      "type": "text",
      "id": "rented_title",
      "label": "Title",
      "default": "Built on someone else's platform"
    },
    {
      "type": "header",
      "content": "Owned panel"
    },
    {
      "type": "text",
      "id": "owned_label",
      "label": "Label",
      "default": "Owned"
    },
    {
      "type": "text",
      "id": "owned_title",
      "label": "Title",
      "default": "Built on assets you control"
    },
    {
      "type": "text",
      "id": "footline",
      "label": "Closing line",
      "default": "Social media is where fans find you. Email is where they stay."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "rented_item",
      "name": "Rented item",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Text",
          "default": "An algorithm decides who sees your work"
        }
      ]
    },
    {
      "type": "owned_item",
      "name": "Owned item",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "Text",
          "default": "Your email list reaches fans every time"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DJK Rented vs Owned",
      "blocks": [
        { "type": "rented_item", "settings": { "text": "An algorithm decides who sees your work" } },
        { "type": "rented_item", "settings": { "text": "Reach drops the moment you stop posting" } },
        { "type": "rented_item", "settings": { "text": "One policy change can erase years of effort" } },
        { "type": "rented_item", "settings": { "text": "You never get fan contact information" } },
        { "type": "owned_item", "settings": { "text": "Your email list reaches fans every time" } },
        { "type": "owned_item", "settings": { "text": "Your website works for you around the clock" } },
        { "type": "owned_item", "settings": { "text": "Fan relationships compound year after year" } },
        { "type": "owned_item", "settings": { "text": "You sell direct and keep the margin" } }
      ]
    }
  ]
}
{% endschema %}
