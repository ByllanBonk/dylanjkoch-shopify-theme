{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="djk-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="djk-container">
    <div class="djk-section-head djk-section-head--center djk-reveal">
      {%- if section.settings.eyebrow != blank -%}
        <p class="djk-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="djk-heading djk-heading--lg">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="djk-lead">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="djk-services__grid">
      {%- for block in section.blocks -%}
        <div
          class="djk-card djk-card--hover djk-service-card{% if block.settings.featured %} djk-service-card--featured{% endif %} djk-reveal"
          style="--djk-delay: {{ forloop.index0 | times: 0.1 }}s;"
          {{ block.shopify_attributes }}
        >
          <span class="djk-service-card__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'call' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M21 16.9v2.5a1.6 1.6 0 01-1.8 1.6 19.4 19.4 0 01-8.5-3 19.1 19.1 0 01-5.9-5.9 19.4 19.4 0 01-3-8.5A1.6 1.6 0 013.4 2h2.5a1.6 1.6 0 011.6 1.4c.1.9.3 1.8.6 2.6a1.6 1.6 0 01-.4 1.7L6.7 8.8a16 16 0 005.9 5.9l1.1-1a1.6 1.6 0 011.7-.4c.8.3 1.7.5 2.6.6a1.6 1.6 0 011.4 1.6z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- when 'coaching' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2m20 0v-2a4 4 0 00-3-3.9M15 3.1a4 4 0 010 7.8M13 7a4 4 0 11-8 0 4 4 0 018 0z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- when 'system' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M4 4h6v6H4zM14 4h6v6h-6zM4 14h6v6H4zM17 11v3m0 0v3m0-3h3m-3 0h-3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- when 'mail' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M4 4h16a2 2 0 012 2v12a2 2 0 01-2 2H4a2 2 0 01-2-2V6a2 2 0 012-2z" stroke="currentColor" stroke-width="1.6"/><path d="M22 7l-10 6L2 7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {%- when 'drum' -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><ellipse cx="12" cy="7.5" rx="9" ry="3.5" stroke="currentColor" stroke-width="1.6"/><path d="M3 7.5V16c0 1.9 4 3.5 9 3.5s9-1.6 9-3.5V7.5M7.5 10.4V19m9-8.6V19" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
              {%- else -%}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2l2.4 7.2L22 12l-7.6 2.8L12 22l-2.4-7.2L2 12l7.6-2.8L12 2z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
            {%- endcase -%}
          </span>

          <h3 class="djk-service-card__title">{{ block.settings.title }}</h3>
          <p class="djk-service-card__text">{{ block.settings.text }}</p>

          {%- if block.settings.feature_1 != blank or block.settings.feature_2 != blank or block.settings.feature_3 != blank -%}
            <ul class="djk-service-card__list">
              {%- if block.settings.feature_1 != blank -%}<li>{{ block.settings.feature_1 }}</li>{%- endif -%}
              {%- if block.settings.feature_2 != blank -%}<li>{{ block.settings.feature_2 }}</li>{%- endif -%}
              {%- if block.settings.feature_3 != blank -%}<li>{{ block.settings.feature_3 }}</li>{%- endif -%}
            </ul>
          {%- endif -%}

          <div class="djk-service-card__foot">
            {%- if block.settings.price_note != blank -%}
              <span class="djk-service-card__price">{{ block.settings.price_note }}</span>
            {%- endif -%}
            {%- if block.settings.button_text != blank -%}
              <a href="{{ block.settings.button_link | default: '#' }}" class="djk-btn {% if block.settings.featured %}djk-btn--gold{% else %}djk-btn--ghost{% endif %}">
                {{ block.settings.button_text }}
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "DJK Work With Me",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Work With Me"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Three ways to build your system"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text",
      "default": "<p>Pick the level of help that fits where you are right now.</p>"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service card",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "call", "label": "Phone call" },
            { "value": "coaching", "label": "People" },
            { "value": "system", "label": "System grid" },
            { "value": "mail", "label": "Email" },
            { "value": "drum", "label": "Drum" },
            { "value": "spark", "label": "Spark" }
          ],
          "default": "call"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Strategy Call"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "A focused session on your audience, content, and revenue. You leave with a plan."
        },
        {
          "type": "text",
          "id": "feature_1",
          "label": "Feature 1",
          "default": "90 minutes, one on one"
        },
        {
          "type": "text",
          "id": "feature_2",
          "label": "Feature 2",
          "default": "Full audit before the call"
        },
        {
          "type": "text",
          "id": "feature_3",
          "label": "Feature 3",
          "default": "Written action plan after"
        },
        {
          "type": "text",
          "id": "price_note",
          "label": "Price note",
          "default": "One session"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Book A Call"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "checkbox",
          "id": "featured",
          "label": "Highlight this card (gold)",
          "default": false
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "DJK Work With Me",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "icon": "call",
            "title": "Strategy Call",
            "text": "A focused session on your audience, content, and revenue. You leave with a plan you can run on your own.",
            "feature_1": "90 minutes, one on one",
            "feature_2": "Full audit before the call",
            "feature_3": "Written action plan after",
            "price_note": "One session",
            "button_text": "Book A Call"
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "coaching",
            "title": "Coaching",
            "text": "Ongoing work together while you build your direct-to-fan system. Accountability, feedback, and adjustments as you go.",
            "feature_1": "Monthly working sessions",
            "feature_2": "Direct access between calls",
            "feature_3": "Systems built with you, not for you",
            "price_note": "Monthly",
            "button_text": "Apply For Coaching",
            "featured": true
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "system",
            "title": "Content Systems",
            "text": "Done with you setup of your content engine. Email, lead magnets, automation, and a publishing workflow that fits your life.",
            "feature_1": "Email platform and automation setup",
            "feature_2": "Lead magnet and funnel build",
            "feature_3": "Repeatable publishing workflow",
            "price_note": "Project based",
            "button_text": "Start A Project"
          }
        }
      ]
    }
  ]
}
{% endschema %}
